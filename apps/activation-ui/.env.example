# Copy to .env.local and fill in. .env.local is gitignored.

# Activation mode. Unset (default) = fully simulated: the app runs with no wallet and no sponsor
# secret (a demo address, a placeholder build, a fake submit) — good for local dev and previews.
# Set both of these to "live" to touch the chain for real (real wallet + sponsored submission).
# ACTIVATION_MODE=live              # server: enables real build + sponsor signing + submission
# NEXT_PUBLIC_ACTIVATION_MODE=live  # client: enables the real wallet connect + signing

# Network: "testnet" (default) or "public". Selects the passphrase and default Horizon.
STELLAR_NETWORK=testnet
# Client-side network for the wallet kit. Must match STELLAR_NETWORK.
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Sponsor account that pays the trustline reserve (so users need no XLM). Server-side only.
# Generate + fund one on testnet:
#   node -e 'import("@stellar/stellar-sdk").then(async ({Keypair})=>{const k=Keypair.random();await fetch("https://friendbot.stellar.org?addr="+k.publicKey());console.log(k.publicKey(),k.secret())})'
SPONSOR_SECRET=
SPONSOR_PUBLIC=

# Override the Horizon endpoint (optional; defaults to the network's public Horizon).
# HORIZON_URL=https://horizon-testnet.stellar.org

# Optional SEP-8 approval server for regulated assets we control.
# APPROVAL_SERVER_URL=

# --- Production gating for the sponsor-spending API routes -----------------------------------
# Comma-separated origins allowed to call the activation API. Empty = permissive (dev only).
# ALLOWED_ORIGINS=https://activate.yourbroker.example
# Per-IP requests per minute (default 30). build/submit are gated tighter internally.
# RATE_LIMIT_PER_MINUTE=30
