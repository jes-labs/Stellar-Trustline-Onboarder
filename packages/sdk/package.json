{
  "name": "@trustline-onboarder/sdk",
  "version": "0.1.0",
  "description": "Adopter-facing SDK for wallets and brokers — detect, onboard, verify",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "15.1.0",
    "@trustline-onboarder/core": "workspace:*",
    "@trustline-onboarder/signer": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.18.10",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
